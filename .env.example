# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080
APP_VERSION=dev
PUBLIC_BASE_URL=http://localhost:8080

# ── Database / Redis ─────────────────────────────────────────────────────────
# App connects as the NON-superuser app_user so Row-Level Security engages.
PG_HOST=localhost
PG_PORT=5432
PG_USER=app_user
PG_PASSWORD=app_pw
PG_DB=lumia
PG_SSLMODE=disable
# Migrations run as the superuser (creates roles, extensions, tables).
MIGRATE_DATABASE_URL=postgres://lumia:lumia@localhost:5432/lumia?sslmode=disable
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── Secrets at rest (AES-256-GCM) ──────────────────────────────────────────────
# 32-byte key, hex-encoded (64 hex chars). Leave empty to disable (dev only).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TIMEOUT=60s

# ── Evolution API V2 ───────────────────────────────────────────────────────────
EVOLUTION_BASE_URL=http://localhost:8081
EVOLUTION_API_KEY=changeme
EVOLUTION_WEBHOOK_URL=http://localhost:8080/api/v1/webhooks/evolution
EVOLUTION_WEBHOOK_TOKEN=change-me
EVOLUTION_TIMEOUT=30s

# ── Worker / Orchestration ─────────────────────────────────────────────────────
WORKER_CONCURRENCY=8
WORKER_STREAM=stream:inbound
WORKER_GROUP=orchestrators
DEBOUNCE_SECONDS=8

# ── Security ────────────────────────────────────────────────────────────────────
# Per-tenant request cap per minute (0 disables).
RATE_LIMIT_PER_MINUTE=600

# ── Storage (MinIO / S3-compatible) ──────────────────────────────────────────────
# Inside docker-compose use minio:9000; from the host use localhost:9000.
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lumia
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1

# ── Email (Resend) ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com
